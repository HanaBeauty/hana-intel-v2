# Configurações DB (Read-Only do atual e futuro Read-Write)
DATABASE_URL=postgresql://user:password@host:5432/dbname
POSTGRES_SCHEMA=public

# IA Keys
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here

# Shopify API (Admin)
SHOPIFY_STORE_URL=your_store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# Evolution API / WhatsApp
EVOLUTION_API_URL=https://api.whatsapp.vps_ip.com
EVOLUTION_API_TOKEN=global_apikey_here

# E-mail (SMTP)
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_USER=marketing@yourdomain.com
SMTP_PASS=strangepassword123

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# App Settings
ENVIRONMENT=development
PORT=8000
